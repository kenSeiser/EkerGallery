# --- TEMİZLİK ROTASI (YENİ EKLENEN KISIM) ---
@app.route('/clean-duplicates', methods=['POST'])
def clean_duplicates():
    if not session.get('logged_in'): return redirect(url_for('login'))
    
    try:
        # Veritabanına bağlan
        client = MongoClient(mongo_uri, tlsCAFile=certifi.where())
        db = client["sahibinden_data"]
        col = db["tum_araclar"]
        
        # Aynı URL'ye sahip olanları bul
        pipeline = [
            {"$group": {
                "_id": "$url", 
                "ids": {"$push": "$_id"},
                "count": {"$sum": 1}
            }},
            {"$match": {"count": {"$gt": 1}}}
        ]
        
        duplicates = list(col.aggregate(pipeline))
        deleted_count = 0
        
        # Sadece en son ekleneni tut, diğerlerini sil
        for doc in duplicates:
            ids_to_remove = doc['ids'][:-1] 
            if ids_to_remove:
                col.delete_many({"_id": {"$in": ids_to_remove}})
                deleted_count += len(ids_to_remove)
                
        print(f"TEMİZLİK RAPORU: {deleted_count} adet kopya ilan silindi.")
        
    except Exception as e:
        print(f"Hata oluştu: {e}")
        
    return redirect(url_for('home'))

