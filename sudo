            model = MLPRegressor(hidden_layer_sizes=(64, 32), max_iter=500)
            model.fit(X_s, y_s)

            weights = np.abs(model.coefs_[0])
            sums = np.sum(weights, axis=1)
            total = np.sum(sums) if np.sum(sums) > 0 else 1
