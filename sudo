            fiyat = 0
            if isinstance(veri.get('price'), str):
                try: fiyat = int(veri.get('price').split('TL')[0].replace('.', '').strip())
                except: pass
            elif isinstance(veri.get('price'), int): fiyat = veri.get('price')
            
