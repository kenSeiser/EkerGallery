            except: yil = 0
            try: km = int(str(veri.get('details', {}).get('KM', veri.get('km', '0'))).replace('.', '').replace(' km', '').strip())
            except: km = 0

            title_upper = str(veri.get('title', '')).upper()
            hasar_puan, hasar_metni = 5, "Belirtilmemiş"
            if 'HATASIZ' in title_upper or 'BOYASIZ' in title_upper: hasar_puan, hasar_metni = 10, "HATASIZ"
            elif 'HASAR' in title_upper or 'AĞIR' in title_upper: hasar_puan, hasar_metni = 0, "HASARLI"

