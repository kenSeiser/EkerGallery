# ========================================
# EkerGallery - Ortam Değişkenleri
# ========================================
# 
# Bu dosyayı .env olarak kopyalayın ve değerleri güncelleyin:
# cp .env.example .env
#
# ⚠️ UYARI: .env dosyasını asla Git'e commit etmeyin!
#

# MongoDB Atlas Bağlantı URI'si
MONGO_URI=mongodb+srv://kullanici:sifre@cluster.mongodb.net/?retryWrites=true&w=majority

# Flask Gizli Anahtar (rastgele üretilmeli)
SECRET_KEY=buraya-guclu-rastgele-bir-anahtar-yazin

# Admin Kimlik Bilgileri
ADMIN_USER=admin
ADMIN_PASS=guclu-bir-sifre-belirleyin

# Chrome Driver Sürümü
CHROME_VERSION=144

# Scraping Ayarları
SCRAPE_INTERVAL_HOURS=4
MAX_PAGES_PER_CATEGORY=10
